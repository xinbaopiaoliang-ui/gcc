[Unit]
Description=gaccel QUIC relay node
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=gaccel
Group=gaccel
ExecStart=/usr/local/bin/gaccel-node -config /etc/gaccel-node/config.yaml
Restart=on-failure
RestartSec=3s
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/gaccel-node

[Install]
WantedBy=multi-user.target
